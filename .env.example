# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=fundme_malawi

# Auth
JWT_SECRET=your_super_secret_jwt_key_here
API_KEY_SECRET=your_api_key_secret

# Email (nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=FundMe Malawi <noreply@fundmemalawi.com>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File uploads
UPLOAD_DIR=uploads

# Airtel Money
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_COUNTRY=MW
AIRTEL_CURRENCY=MWK
AIRTEL_CALLBACK_URL=https://yourdomain.com/api/payments/airtel/callback

# TNM Mpamba
TNM_BASE_URL=https://api.mpamba.tnm.co.mw
TNM_API_KEY=your_tnm_api_key
TNM_MERCHANT_CODE=your_merchant_code
TNM_CALLBACK_URL=https://yourdomain.com/api/payments/tnm/callback
